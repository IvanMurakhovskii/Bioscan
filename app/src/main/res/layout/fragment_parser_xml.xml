<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

  <android.support.constraint.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:padding="@dimen/default_padding_bottom">

    <!-- Left Hand Section -->
    <android.support.v7.widget.CardView
        android:id="@+id/card_left_hand"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/left_hand"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"/>

        <TextView
            android:id="@+id/tv_file_name_left_hand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:text="@string/no_choice_select"
            android:textSize="16sp"
            android:textColor="@color/secondary_text"/>

        <android.support.v7.widget.AppCompatButton
            android:id="@+id/btn_add_left_hand_file"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:text="@string/add_file"
            android:textColor="@android:color/white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

      </LinearLayout>
    </android.support.v7.widget.CardView>

    <!-- Right Hand Section -->
    <android.support.v7.widget.CardView
        android:id="@+id/card_right_hand"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_left_hand">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/right_hand"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"/>

        <TextView
            android:id="@+id/tv_file_name_right_hand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:text="@string/no_choice_select"
            android:textSize="16sp"
            android:textColor="@color/secondary_text"/>

        <android.support.v7.widget.AppCompatButton
            android:id="@+id/btn_add_right_hand_file"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:text="@string/add_file"
            android:textColor="@android:color/white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

      </LinearLayout>
    </android.support.v7.widget.CardView>

    <!-- Settings Section -->
    <android.support.v7.widget.CardView
        android:id="@+id/card_settings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_right_hand">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="8dp">

        <!-- Description Input -->
        <android.support.design.widget.TextInputLayout
            android:id="@+id/til_descr_xml"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/comment"
            app:boxStrokeColor="@color/colorPrimary">

          <EditText
              android:id="@+id/etDescription_xml"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:minHeight="48dp"
              android:background="@android:color/transparent"/>

        </android.support.design.widget.TextInputLayout>

        <!-- Gender Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="Пол"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"/>

        <RadioGroup
            android:id="@+id/rg_gender_xml"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

          <RadioButton
              android:id="@+id/rb_male_xml"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginEnd="16dp"
              android:checked="true"
              android:text="Муж"
              android:buttonTint="@color/colorPrimary"/>

          <RadioButton
              android:id="@+id/rb_feminine_xml"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Жен"
              android:buttonTint="@color/colorPrimary"/>

        </RadioGroup>

        <!-- Practice Switch -->
        <android.support.v7.widget.SwitchCompat
            android:id="@+id/sc_practice_xml"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/practice"
            android:textSize="16sp"
            app:trackTint="@color/switch_track"
            app:thumbTint="@color/colorPrimary"/>

      </LinearLayout>
    </android.support.v7.widget.CardView>

    <!-- Save Button -->
    <android.support.v7.widget.AppCompatButton
        android:id="@+id/btnSaveFromXml"
        style="@android:style/DeviceDefault.SegmentedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@color/colorPrimary"
        android:drawableLeft="@drawable/ic_save_black_24dp"
        android:elevation="4dp"
        android:text="@string/save"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_settings" />

  </android.support.constraint.ConstraintLayout>
</ScrollView>