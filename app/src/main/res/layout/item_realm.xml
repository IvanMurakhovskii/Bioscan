<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardUseCompatPadding="true">

    <android.support.constraint.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Заголовок алгоритма -->
        <TextView
            android:id="@+id/tvAlgorithm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Алгоритм анализа"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            app:layout_constraintEnd_toStartOf="@+id/tvMeasurePoint"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Точка измерения -->
        <TextView
            android:id="@+id/tvMeasurePoint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Точка измерения"
            android:textSize="14sp"
            android:textColor="#666666"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvAlgorithm"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Время измерения -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="12:30 • 25 дек 2024"
            android:textSize="16sp"
            android:textColor="#666666"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvAlgorithm" />

        <!-- Описание результатов -->
        <TextView
            android:id="@+id/result_descriptions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:text="Результаты анализа показали нормальные значения по всем параметрам"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintEnd_toStartOf="@+id/guideline_actions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTime" />

        <!-- Guideline для разделения контента и действий -->
        <android.support.constraint.Guideline
            android:id="@+id/guideline_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.7" />

        <!-- Контейнер для кнопок действий -->
        <LinearLayout
            android:id="@+id/actions_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/guideline_actions"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Кнопка экспорта -->
            <android.support.design.button.MaterialButton
                android:id="@+id/btn_export"
                style="@style/Widget.App.Button.OutlinedButton.IconOnly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                app:icon="@android:drawable/stat_sys_download_done"
                app:iconTint="@color/colorPrimary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnDelete"
                app:layout_constraintTop_toBottomOf="@+id/tvAlgorithm" />

            <android.support.design.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.App.Button.OutlinedButton.IconOnly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                app:icon="@android:drawable/ic_delete"
                app:iconTint="@color/colorResultRed"
                app:layout_constraintBottom_toBottomOf="parent" />

        </LinearLayout>

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#E0E0E0"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/result_descriptions" />

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>